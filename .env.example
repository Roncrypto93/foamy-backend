PORT=3000

# Endpoint API Open-Meteo (non richiedono API key per uso non commerciale)
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_MARINE_URL=https://marine-api.open-meteo.com/v1/marine

# TTL della cache forecast, in secondi (usato sia per la cache in-memory
# locale sia per Upstash Redis sotto). Default 10800 = 180 minuti, per
# stare ampiamente dentro la quota gratuita giornaliera di Open-Meteo.
FORECAST_CACHE_TTL=10800

# Cache persistente (Upstash Redis, via REST — nessuna libreria client
# necessaria). Opzionale: se non impostate, si usa solo la cache in-memory
# (che su Render free si azzera ad ogni riavvio/sleep del servizio, quindi
# senza Upstash la quota Open-Meteo si esaurisce più facilmente). Account
# gratuito su upstash.com > Redis > Create Database > REST API.
# UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxx
UPSTASH_TIMEOUT_MS=5000

# Copernicus Marine (CMEMS) - script Python invocato come sottoprocesso.
# Le credenziali NON vanno qui: si impostano una volta sola sulla macchina
# che esegue il backend con `copernicusmarine login` (salvate in
# $HOME/.copernicusmarine-credentials), oppure via le env ufficiali del
# toolbox COPERNICUSMARINE_SERVICE_USERNAME / COPERNICUSMARINE_SERVICE_PASSWORD.
PYTHON_BIN=python3
COPERNICUS_TIMEOUT_MS=20000
# Opzionale: forza un dataset_id specifico (vedi scripts/fetch_copernicus_wave.py).
# COPERNICUS_DATASET_ID=cmems_mod_med_wav_anfc_4.2km_PT1H-i

# Usato SOLO dal forecast a 3 giorni (GET /api/forecast/:spotId/daily):
# URL del microservizio foamy-copernicus (Flask, dataset anfc con orizzonte
# di forecast reale). Le condizioni attuali non usano questa variabile.
COPERNICUS_SERVICE_URL=http://localhost:5000
# Timeout per singola chiamata a foamy-copernicus (ms). Più alto del timeout
# del subprocess Python perché ogni chiamata riapre un dataset CMEMS da zero,
# lento su hosting free-tier.
COPERNICUS_DAILY_TIMEOUT_MS=45000
